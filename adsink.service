[Unit]
Description=Local DNS-based ad blocker
After=network.target

[Service]
ExecStart=/usr/local/bin/adsink run
Restart=on-failure
RestartSec=5

# Data directory for blocklists
Environment=adsink_DATA=/var/lib/adsink

# Allow binding port 53 without full root
AmbientCapabilities=CAP_NET_BIND_SERVICE
CapabilityBoundingSet=CAP_NET_BIND_SERVICE
NoNewPrivileges=true

# Minimal sandbox
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/var/lib/adsink
PrivateTmp=true

[Install]
WantedBy=multi-user.target
